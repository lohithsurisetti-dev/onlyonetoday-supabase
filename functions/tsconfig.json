{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext", "dom", "deno.ns"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "**/*.ts",
    "deno.d.ts"
  ]
}

